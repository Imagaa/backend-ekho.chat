APP_NAME=Ekho.chat
# local | production
APP_ENV=local
APP_KEY=
# WAJIB false di production — true membocorkan stack trace & detail env ke response error.
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# === DATABASE (PostgreSQL) ===
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ekho_chat
DB_USERNAME=
DB_PASSWORD=

# === SESSION — dipakai HANYA oleh panel Superadmin (Filament, cookie-based).
# API tenant murni Bearer token, TIDAK pakai session sama sekali. ===
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# WAJIB diisi domain asli di production (mis. .ekho.imaga.site) — jangan "localhost".
SESSION_DOMAIN=localhost
# WAJIB true di production (HTTPS) supaya cookie sesi admin tidak bisa disadap di jalur HTTP.
SESSION_SECURE_COOKIE=false

# === REDIS — cache, queue, rate limiter, session ===
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
FILESYSTEM_DISK=local

# === REVERB (WebSocket realtime — chat masuk, progres import/campaign) ===
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
# http (local) | https (production, di belakang TLS-terminating proxy)
REVERB_SCHEME=http

# === RESEND — kirim email OTP login ===
RESEND_API_KEY=
RESEND_FROM_ADDRESS=auth@ekho.imaga.site

# === WABA — api.co.id (reseller, 1 API key untuk SEMUA tenant). Lihat documentation.md §7 ===
APICOID_BASE_URL=https://chat.api.co.id/api/v1/public
APICOID_API_KEY=
APICOID_WEBHOOK_SECRET=

# === MIDTRANS — top-up saldo wallet ===
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
# WAJIB true di production (pakai Snap.js & endpoint Midtrans production, bukan sandbox).
MIDTRANS_IS_PRODUCTION=false

# === CORS / FRONTEND — dashboard tenant (Next.js) ===
# Origin frontend tenant. Wildcard '*.vercel.app' sudah otomatis dicover di
# config/cors.php, tidak perlu ditulis di sini.
FRONTEND_URL=http://localhost:3000

# === SUPERADMIN (Filament) ===
# Subdomain khusus panel admin (mis. admin.ekho.imaga.site). Kosong = panel
# jalan di domain manapun (dipakai untuk local dev) — WAJIB diisi di production.
ADMIN_DOMAIN=
